# Server environment variables — copy to server/.env and fill in.

# PostgreSQL connection string
DATABASE_URL=

# Auth secrets (use long random strings in production)
JWT_SECRET=
SESSION_SECRET=

# Claude API key (for future AI features)
ANTHROPIC_API_KEY=

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# 32-byte hex key used to encrypt stored integration API keys
ENCRYPTION_KEY=

# CRM OAuth app credentials
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=

# Frontend URL (used for CORS and Stripe/CRM redirect URLs)
# Production: https://www.revara.ai
CLIENT_URL=http://localhost:5173
